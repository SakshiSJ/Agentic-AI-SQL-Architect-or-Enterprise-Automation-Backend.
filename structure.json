"tbl_ap_loader_master": {
  "description": "Master table storing loader, packer, belt, and queue configuration for each plant. Used for loader-wise, packer-wise, capacity, and status related operational queries. Static configuration data.",
  "primary_key": "ID",

  "columns": {
    "ID": {
      "data_type": "BIGINT",
      "description": "Auto-increment unique identifier for loader master record"
    },

    "LOADER_ID": {
      "data_type": "STRING",
      "description": "Unique loader identifier"
    },

    "LOADER_ALIAS": {
      "data_type": "STRING",
      "description": "Logical alias name of the loader"
    },

    "LOADER_CATEGORY": {
      "data_type": "ENUM",
      "enum_name": "PACK_TYPE",
      "description": "Loader category such as BAG or BULK"
    },

    "LOADER_STATUS": {
      "data_type": "ENUM",
      "enum_name": "LOADER_STATUS",
      "description": "Operational status of loader (ACTIVE / INACTIVE)"
    },

    "PACKER_NO": {
      "data_type": "STRING",
      "description": "Packer number mapped to the loader"
    },

    "PACKER_ALIAS": {
      "data_type": "STRING",
      "description": "Logical alias name of the packer"
    },

    "BELT_ID": {
      "data_type": "STRING",
      "nullable": true,
      "description": "Belt identifier associated with the loader"
    },

    "BELT_NAME": {
      "data_type": "STRING",
      "nullable": true,
      "description": "Name of the belt associated with the loader"
    },

    "MIN_ALLOWABLE_QTY": {
      "data_type": "INTEGER",
      "description": "Minimum allowable loading quantity for the loader"
    },

    "MAX_ALLOWABLE_QTY": {
      "data_type": "INTEGER",
      "description": "Maximum allowable loading quantity for the loader"
    },

    "QUEUE_LENGTH": {
      "data_type": "INTEGER",
      "description": "Maximum number of vehicles allowed in queue for the loader"
    },

    "AP_PLANT_CODE": {
      "data_type": "STRING",
      "description": "Plant code where the loader is configured"
    },

    "INACTIVE_REMARK": {
      "data_type": "STRING",
      "nullable": true,
      "description": "Remarks entered when loader is marked inactive"
    },

    "ADDED_BY": {
      "data_type": "STRING",
      "nullable": true,
      "description": "User who created the loader configuration"
    },

    "MODIFIED_BY": {
      "data_type": "STRING",
      "nullable": true,
      "description": "User who last modified the loader configuration"
    },

    "createdDate": {
      "data_type": "DATETIME",
      "description": "Timestamp when the loader record was created"
    },

    "MODIFIED_DATE": {
