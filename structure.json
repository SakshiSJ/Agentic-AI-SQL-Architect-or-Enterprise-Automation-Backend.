{
  "version": "1.0",
  "phase": "phase_1_live_operations",
  "description": "Semantic structure for live operational queries on Phase-1 tables only. No assumptions. No default filters.",

  "tables": {
    "tbl_ap_active_trips": {

  "description": "Stores live vehicle trips currently active inside the plant. Used for real-time monitoring of vehicle stage, movement type (Inbound/Outbound), plant presence, DI attachment, PGI status, weight progression, transporter details, and operational routing information.",
  "time_column": "DTCREATED",

"authoritative_for": [
  "LIVE_STATUS",
  "CURRENT_STATUS",
  "TRIP_LOOKUP",
  "YARD_TRACKING",
  "LOADER_LOOKUP",
  "PACKER_LOOKUP"
]
,

  "primary_key": "ID",

  "allowed_aggregations": ["COUNT"],

  "forbidden_logic": [
    "JOIN",
    "SUBQUERY",
    "CURRENT_DATE",
    "NOW",
    "INTERVAL",
    "TIMESTAMPDIFF"
  ],

  "columns": {

    "ID": {
      "data_type": "BIGINT",
      "description": "Internal unique auto-generated identifier for the trip record"
    },

    "TRIP_ID": {
      "data_type": "STRING",
      "description": "Business trip identifier"
    },

    "TRIP_STATUS": {
      "data_type": "ENUM",
      "enum_name": "TRIP_STATUS",
      "description": "Lifecycle status of the trip (Active, Closed, etc.)"
    },

    "TRIP_MODE": {
      "data_type": "STRING",
      "description": "Mode of trip creation (Manual / System generated)"
    },

    "VEHICLE_NO": {
      "data_type": "STRING",
      "description": "Vehicle registration number"
    },

    "PLANT_CODE": {
      "data_type": "STRING",
      "description": "Plant code where vehicle is currently present"
    },

    "PARENT_PLANT_CODE": {
      "data_type": "STRING",
      "description": "Parent plant code for hierarchical grouping"
    },

    "CURRENT_STATUS": {
      "data_type": "ENUM",
      "enum_name": "CURRENT_STATUS",
      "description": "Current operational stage of the vehicle inside the plant"
    },

    "CURRENT_STAGE_ID": {
      "data_type": "INTEGER",
      "description": "Numeric stage identifier"
    },

    "STAGE_SEQUENCE_ID": {
      "data_type": "INTEGER",
      "description": "Sequence order of the current stage"
    },

    "MOVEMENT_TYPE": {
      "data_type": "ENUM",
      "enum_name": "MOVEMENT_TYPE",
      "description": "Inbound or Outbound vehicle movement"
    },

    "ON_HOLD": {
      "data_type": "ENUM",
      "enum_name": "ON_HOLD",
      "description": "Indicates whether trip is on hold (Y/N)"
    },

    "PACK_TYPE": {
      "data_type": "ENUM",
      "enum_name": "PACK_TYPE",
      "description": "Loading category (BAG / BULK)"
    },

    "MARKETING_CODE": {
      "data_type": "STRING",
      "description": "Marketing material code or grade classification"
    },

    "MANUFACTURING_CODE": {
      "data_type": "STRING",
      "description": "Manufacturing code of material"
    },

    "DI_NO": {
      "data_type": "STRING",
      "nullable": true,
      "description": "Delivery Instruction number attached to trip"
    },

    "PGI_STATUS": {
      "data_type": "ENUM",
      "enum_name": "PGI_STATUS",
      "nullable": true,
      "description": "Post Goods Issue processing status"
    },

    "PGI_DATE": {
      "data_type": "DATETIME",
      "nullable": true,
      "description": "Timestamp when PGI was completed"
    },

    "FIRST_WT": {
      "data_type": "DECIMAL",
      "description": "First weight recorded at weighbridge"
    },

    "SECOND_WT": {
      "data_type": "DECIMAL",
      "description": "Second weight recorded at weighbridge"
    },

    "NET_WT": {
      "data_type": "DECIMAL",
      "description": "Net material weight"
    },

    "FIRST_WT_TIME": {
      "data_type": "DATETIME",
      "nullable": true,
      "description": "Timestamp of first weight entry"
    },

    "SECOND_WT_TIME": {
      "data_type": "DATETIME",
      "nullable": true,
      "description": "Timestamp of second weight entry"
    },

    "FIRST_WEIGHT_WB_NO": {
      "data_type": "STRING",
      "nullable": true,
      "description": "Weighbridge number used for first weight"
    },

    "SECOND_WEIGHT_WB_NO": {
      "data_type": "STRING",
      "nullable": true,
      "description": "Weighbridge number used for second weight"
    },

    "TRANSPORTER_CODE": {
      "data_type": "STRING",
      "description": "Unique transporter identifier"
    },

    "TRANSPORTER_NAME": {
      "data_type": "STRING",
      "description": "Name of the transporter"
    },

    "LR_STATUS": {
      "data_type": "STRING",
      "nullable": true,
      "description": "LR document processing status"
    },

    "LR_TRANSPORTER_CODE": {
      "data_type": "STRING",
      "nullable": true,
      "description": "LR transporter code"
    },

    "ROUTE_NAME": {
      "data_type": "STRING",
      "nullable": true,
      "description": "Route assigned for delivery"
    },

    "TAT_STATUS": {
      "data_type": "STRING",
      "nullable": true,
      "description": "Turnaround time monitoring status"
    },

    "BACKHAUL_FLAG": {
      "data_type": "STRING",
      "nullable": true,
      "description": "Indicates whether trip is part of backhaul"
    },

    "BACKHAUL_LINKED_TRIP": {
      "data_type": "STRING",
      "nullable": true,
      "description": "Linked trip ID for backhaul reference"
    },

    "ABORTED_REMARKS": {
      "data_type": "STRING",
      "nullable": true,
      "description": "Remarks if trip was aborted"
    },

    "GW_TOL_APPVD_BY": {
      "data_type": "STRING",
      "nullable": true,
      "description": "User who approved gross weight tolerance"
    },

    "PO_RECON_FLAG": {
      "data_type": "STRING",
      "nullable": true,
      "description": "Indicates whether PO reconciliation is completed"
    },

    "CANCEL_DO_QTY": {
      "data_type": "DECIMAL",
      "nullable": true,
      "description": "Cancelled Delivery Order quantity"
    },

    "ASN_APPROVE_FLAG": {
      "data_type": "STRING",
      "nullable": true,
      "description": "ASN approval indicator"
    },

    "ASN_ID": {
      "data_type": "BIGINT",
      "nullable": true,
      "description": "ASN record identifier"
    },

    "DTCREATED": {
      "data_type": "DATETIME",
      "description": "Trip creation timestamp"
    },

    "SYSTIME": {
      "data_type": "DATETIME",
      "description": "System update timestamp"
    }
  }
}
,"tbl_ap_plant_device_status": {
  "description": "Stores plant-level installed devices, their operational status, type, IP, and validity period.",
  "primary_key": "ID",

  "columns": {
    "ID": {
      "data_type": "BIGINT",
      "description": "Unique device record identifier"
    },

    "DEVICE_IP": {
      "data_type": "STRING",
      "description": "IP address of the device"
    },

    "DEVICE_NAME": {
      "data_type": "STRING",
      "description": "Logical name of the installed device"
    },

    "DEVICE_STATUS": {
      "data_type": "ENUM",
      "enum_name": "DEVICE_STATUS",
      "description": "Operational status of the device (ON / OFF)"
    },

    "DEVICE_TYPE": {
      "data_type": "ENUM",
      "enum_name": "DEVICE_TYPE",
      "description": "Type of device such as LED, READER, or APD"
    },

    "FROM_DATE": {
      "data_type": "DATETIME",
      "description": "Date and time when the device became active"
    },

    "TO_DATE": {
      "data_type": "DATETIME",
      "description": "Date and time until which the device record is valid"
    },

    "TEST_TIME": {
      "data_type": "DATETIME",
      "description": "Last test or heartbeat timestamp for the device"
    },

    "PLANT_CODE": {
      "data_type": "INTEGER",
      "description": "Plant where the device is installed"
    }
  }
},



    
    
    "tbl_ap_hist_rep_ob": {
  "description": "Stores historical outbound dispatch records. Used for dispatch quantity, vehicle trip count, shift-wise summaries, loading category analytics, and TAT based operational reporting.",
  "time_column": "DTCREATED",

"authoritative_for": [
  "DISPATCH",
  "TAT",
  "QUANTITY",
  "SHIFT_ANALYTICS",
  "HIST_TRIP"
]
,

  "primary_key": "ID",

  "allowed_aggregations": ["COUNT", "SUM", "AVG", "MAX"],

  "forbidden_logic": [
    "JOIN",
    "SUBQUERY",
    "CURRENT_DATE",
    "NOW",
    "INTERVAL",
    "TIMESTAMPDIFF"
  ],

  "columns": {

    "ID": { "data_type": "BIGINT" },

    "TRIP_ID": {
      "data_type": "STRING",
      "description": "Unique trip identifier"
    },

    "TRIP_STATUS": { "data_type": "STRING" },

    "PLANT_CODE": {
      "data_type": "STRING",
      "description": "Plant from which dispatch occurred"
    },

    "PARENT_PLANT_CODE": { "data_type": "STRING" },

    "DTCREATED": {
      "data_type": "DATETIME",
      "description": "Dispatch creation timestamp"
    },

    "SHIFT": {
      "data_type": "ENUM",
      "enum_name": "SHIFT",
      "description": "Operational shift (A/B/C)"
    },

    "VEHICLE_NO": { "data_type": "STRING" },

    "MOVEMENT_TYPE": {
      "data_type": "ENUM",
      "enum_name": "MOVEMENT_TYPE"
    },

    "PACK_TYPE": {
      "data_type": "ENUM",
      "enum_name": "PACK_TYPE"
    },

    "LOAD_CATEGORY": { "data_type": "STRING" },

    "ORDER_TYPE": {
      "data_type": "ENUM",
      "enum_name": "ORDER_TYPE"
    },

    "GRDAE": {
      "data_type": "STRING",
      "description": "Material grade (Note: Column name is GRDAE in DB)"
    },

    "NET_WT": { "data_type": "DECIMAL" },
    "FIRST_WT": { "data_type": "DECIMAL" },
    "SECOND_WT": { "data_type": "DECIMAL" },

    "FIRST_WT_TIME": { "data_type": "DATETIME" },
    "SECOND_WT_TIME": { "data_type": "DATETIME" },

    "FIRST_WEIGHT_WB_NO": { "data_type": "STRING" },
    "SECOND_WEIGHT_WB_NO": { "data_type": "STRING" },

    "DELIVER_QTY": { "data_type": "DECIMAL" },
    "TOTAL_QTY": { "data_type": "DECIMAL" },
    "DI_QTY": { "data_type": "STRING" },

    "DI_NO": { "data_type": "STRING" },
    "DI_DATETIME": { "data_type": "STRING" },
    "DI_TAT": { "data_type": "BIGINT" },
    "TOTAL_DI_TAT": { "data_type": "BIGINT" },

    "YARD_TAT": { "data_type": "BIGINT" },
    "PLANT_TAT": { "data_type": "BIGINT" },
    "TOTAL_TAT": { "data_type": "BIGINT" },

    "PGI_STATUS": {
      "data_type": "ENUM",
      "enum_name": "PGI_STATUS"
    },

    "PGI_DATE": { "data_type": "DATETIME" },
    "PGI_NUMBER": { "data_type": "STRING" },
    "ALL_PGI_DATE": { "data_type": "STRING" },

    "CUSTOMER_NAME": { "data_type": "STRING" },
    "DESTINATION": { "data_type": "STRING" },

    "TRANSPORTER_CODE": { "data_type": "STRING" },
    "TRANSPORTER_NAME": { "data_type": "STRING" },

    "SEQ_LOADER": { "data_type": "STRING" },
    "SEQ_PACKER": { "data_type": "STRING" },
    "ACT_LOADER": { "data_type": "STRING" },
    "ACT_PACKER": { "data_type": "STRING" },

    "READY_QUEUE_TIME": { "data_type": "DATETIME" },

    "DISTRIBUTION_CHANNEL": { "data_type": "STRING" },
    "DISTRICT": { "data_type": "STRING" },

    "SHIP_TO": { "data_type": "STRING" },
    "SHIP_TO_CITY": { "data_type": "STRING" },
    "SHIP_TO_STATE": { "data_type": "STRING" },
    "SHIPT_TO_TEHSIL": { "data_type": "STRING" },
    "SHIP_TO_DISTRICT": { "data_type": "STRING" },

    "BACKHAUL_FLAG": { "data_type": "STRING" },
    "BACKHAUL_LINKED_TRIP": { "data_type": "STRING" },

    "ABORTED_REMARKS": { "data_type": "STRING" },

    "GW_TOL_APPVD_BY": { "data_type": "STRING" },

    "SAP_ORDER_NO": { "data_type": "STRING" },
    "INVOICE_NO": { "data_type": "STRING" },

    "INV_CNL_FLAG": { "data_type": "STRING" },
    "INV_CNL_DATE": { "data_type": "STRING" },
    "INV_CNL_DI_NO": { "data_type": "STRING" },
    "INV_CNL_GR_CHILD": { "data_type": "STRING" },
    "INV_CNL_INVOICE_NO": { "data_type": "STRING" },
    "INV_CNL_QTY": { "data_type": "STRING" },

    "SRT_FLAG": { "data_type": "STRING" },
    "SRT_TIME": { "data_type": "STRING" },
    "SRT_INVOICE_NO": { "data_type": "STRING" },

    "E_WAY_BILL": { "data_type": "STRING" },
    "MRP": { "data_type": "STRING" },
    "INCOTERM": { "data_type": "STRING" },

    "SYSTIME": { "data_type": "DATETIME" }
  }
}

,"tbl_ap_wb_tol_logs": {
  "description": "Weighbridge tolerance failure log table. Each row represents a tolerance event logged at weighbridge. This table should not be used to derive failure logic using weight comparisons. Every row is treated as a recorded event.",
  "time_column": "DT_CREATED",

"authoritative_for": [
  "TOLERANCE",
  "WEIGHBRIDGE_FAILURE"
]
,

  "primary_key": "ID",

  "phase": "PHASE_1",

  "time_column": "DT_CREATED",

  "allowed_aggregations": ["COUNT"],

  "allowed_group_by": [
    "DT_CREATED",
    "PARENT_PLANT_CODE",
    "LOAD_CATEGORY",
    "MOVEMENT_TYPE",
    "VEHICLE_NO"
  ],

  "forbidden_logic": [
    "WT_DIFF",
    "ACT_WT",
    "EXPECTED_WT",
    "LOWER_LIMIT",
    "UPPER_LIMIT",
    "CURRENT_DATE",
    "INTERVAL",
    "TIMESTAMPDIFF"
  ],

  "default_aggregation": {
    "FUNC": "COUNT",
    "COLUMN": "TRIP_ID",
    "DISTINCT": true
  },

  "columns": {

    "ID": { "data_type": "BIGINT" },

    "TRIP_ID": { "data_type": "STRING" },

    "VEHICLE_NO": { "data_type": "STRING" },

    "PARENT_PLANT_CODE": { "data_type": "STRING" },

    "DT_CREATED": { "data_type": "DATETIME" },

    "MOVEMENT_TYPE": { "data_type": "STRING" },

    "LOAD_CATEGORY": { "data_type": "STRING" },

    "WT_TYPE": { "data_type": "STRING" },

    "ACT_WT": { "data_type": "DECIMAL" },
    "EXPECTED_WT": { "data_type": "DECIMAL" },
    "LOWER_LIMIT": { "data_type": "DECIMAL" },
    "UPPER_LIMIT": { "data_type": "DECIMAL" },
    "WT_DIFF": { "data_type": "DECIMAL" },

    "WT_TIME": { "data_type": "DATETIME" },

    "IS_APPROVED": { "data_type": "STRING" },
    "APPROVED_BY": { "data_type": "STRING" },
    "GW_APPROVAL_TIME": { "data_type": "DATETIME" },
    "TOL_APPROVE": { "data_type": "STRING" },

    "REMARKS": { "data_type": "STRING" },

    "WEB_NO": { "data_type": "STRING" }
  },

  "semantic_rules": {
    "EVENT_NATURE": "FAILURE_LOG",
    "FAILURE_ROWS_ARE_PRECOMPUTED": true,
    "DO_NOT_DERIVE_FAILURE_USING_WEIGHT_COLUMNS": true
  }
}
,

    

    "vw_active_trip": {
      "description": "View containing active vehicle trips with material grade and loading category details. Used for grade-wise and loading category-wise operational queries.",
