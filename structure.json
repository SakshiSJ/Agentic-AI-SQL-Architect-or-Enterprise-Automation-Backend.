        "VEHICLE_NO": { "data_type": "STRING", "description": "Vehicle registration number" },
        "ORDER_TYPE": {"data_type": "STRING","description": "Order type associated with the trip such as STO or SO"},
        "TRANSPORTER_NAME": {
  "data_type": "STRING",
  "description": "Transporter name associated with the trip (available in vw_active_trip)"
},


        "NUMBER_OF_WHEELS": {"data_type": "INTEGER","description": "Number of wheels of the vehicle"},
       "CURRENT_STATUS": { "data_type": "ENUM", "enum_name": "CURRENT_STATUS", "description": "Current operational stage of the vehicle" },
        "MOVEMENT_TYPE": { "data_type": "ENUM", "enum_name": "MOVEMENT_TYPE", "description": "Inbound or outbound movement" },
        "TRIP_STATUS": { "data_type": "ENUM", "enum_name": "TRIP_STATUS", "description": "Lifecycle status of the trip" },
        "ON_HOLD": { "data_type": "ENUM", "enum_name": "ON_HOLD", "description": "Indicates whether the trip is on hold" },
        "GRADE": { "data_type": "ENUM", "enum_name": "GRADE", "description": "Material grade (PPC / OPC / OPC43Gr)" },
        "PACK_TYPE": { "data_type": "ENUM", "enum_name": "PACK_TYPE", "description": "Loading category (Bag / Bulk)" },
        "VEHICLE_OWNERSHIP_TYPE": {"data_type": "STRING", "description": "Ownership type of the vehicle such as Market or Dedicated"
},
"SEQ_PACKER": {
  "data_type": "INTEGER",
  "description": "Packer sequence assigned to the trip"
},
"SEQ_LOADER": {
  "data_type": "INTEGER",
  "description": "Loader sequence assigned to the trip"
},
"FIRST_WT": {
  "data_type": "DECIMAL",
  "description": "First recorded weight for the trip (raw stored value)"
},
"NET_WT": {
      "data_type": "DECIMAL",
      "description": "Net weight of the trip (denormalized in view)"},
"SECOND_WT": {
  "data_type": "DECIMAL",
  "description": "Second recorded weight for the trip (raw stored value)"
}


